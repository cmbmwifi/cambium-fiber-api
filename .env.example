# Cambium Fiber API - Installation Environment Variables
# Usage: cp .env.example .env && vim .env && ./install.sh
#
# NOTE: The install script automatically loads .env if present.
# Uncomment variables below for non-interactive (headless) installation.
# Leave commented for interactive installation with prompts.

# API version to install (e.g., 1.0.0, 1.0.0-beta.1, latest)
#VERSION=1.0.0

# Port for API server (default: 8000)
#API_PORT=8000

# Headless mode: uncomment to skip browser open and wizard prompts
#OPEN_BROWSER=false
